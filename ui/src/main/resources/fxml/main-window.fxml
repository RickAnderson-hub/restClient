<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.restclient.ui.controller.MainWindowController"
            stylesheets="@../css/main.css"
            styleClass="root-pane">

    <!-- Left: workspace / request collection sidebar (placeholder tree) -->
    <left>
        <VBox styleClass="sidebar" minWidth="240" prefWidth="260">
            <Label text="Workspace" styleClass="sidebar-title"/>
            <TreeView fx:id="collectionTree" VBox.vgrow="ALWAYS"/>
        </VBox>
    </left>

    <!-- Center: request bar on top, response viewer below -->
    <center>
        <VBox styleClass="content">
            <!-- Request bar: method + URL + send -->
            <HBox styleClass="request-bar" spacing="8">
                <ComboBox fx:id="methodComboBox" styleClass="method-combo"/>
                <TextField fx:id="urlField" promptText="https://api.example.com/endpoint"
                           HBox.hgrow="ALWAYS"/>
                <Button text="Send" onAction="#onSend" styleClass="send-button"/>
            </HBox>

            <!-- Request/response split -->
            <SplitPane orientation="VERTICAL" dividerPositions="0.4" VBox.vgrow="ALWAYS">
                <VBox styleClass="request-editor">
                    <Label text="Request" styleClass="panel-title"/>
                    <TextArea fx:id="requestBodyArea" promptText="Request body (JSON, XML, ...)"
                              VBox.vgrow="ALWAYS"/>
                </VBox>
                <VBox styleClass="response-viewer">
                    <Label text="Response" styleClass="panel-title"/>
                    <TextArea fx:id="responseArea" editable="false" VBox.vgrow="ALWAYS"/>
                </VBox>
            </SplitPane>
        </VBox>
    </center>

    <!-- Bottom: status bar -->
    <bottom>
        <HBox styleClass="status-bar">
            <Label fx:id="statusLabel" text="Ready"/>
        </HBox>
    </bottom>

</BorderPane>
